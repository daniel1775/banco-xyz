{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"strict": true,
		"types": ["jest"],
		"paths": {
			"@/*": ["./*"],
			"@/utils/*": ["./src/utils/*"],
			"@/api/*": ["./src/api/*"],
			"@/store/*": ["./src/store/*"],
			"@/types/*": ["./src/types/*"],
			"@/UI/*": ["./src/UI/*"],
			"@/hooks/*": ["./src/hooks/*"]
		}
	},
	"include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
